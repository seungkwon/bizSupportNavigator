# App
ENVIRONMENT=local

# Postgres (host port 9000 -> container 5432; default 5432 already in use on this machine)
POSTGRES_HOST=localhost
POSTGRES_PORT=9000
POSTGRES_DB=bizsupport
POSTGRES_USER=bizsupport
POSTGRES_PASSWORD=bizsupport

# Chroma (run locally: chroma run --path ./data/chroma --port 8000)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Neo4j (run locally: Neo4j Desktop/Community server, default bolt port 7687)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# OpenAI
OPENAI_API_KEY=

# bizinfo.go.kr Open API
BIZINFO_API_KEY=

# Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Embedding model
EMBEDDING_MODEL_NAME=BAAI/bge-m3
